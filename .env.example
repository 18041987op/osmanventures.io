# Contact form (Resend) — required for /api/contact to send emails.
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. Defaults to osman@osmanventures.io
CONTACT_TO_EMAIL=

# Optional. Must be an address on a domain verified in Resend.
# While testing you can use Resend's shared sender: onboarding@resend.dev
# Example for production: "Osman Ventures <hello@osmanventures.io>"
CONTACT_FROM_EMAIL=
